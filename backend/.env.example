# ---- WAAEM backend environment ----
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=*

# Database — local dev uses async SQLite by default.
# Production (managed PostgreSQL, e.g. Neon / Supabase):
# Paste the connection string from your provider — a plain postgres:// URL is
# auto-normalised to asyncpg. Neon example (note ?sslmode=require):
# DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/waaem?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./waaem.db

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
ALLOWED_EXTENSIONS=pdf,docx

# ---- Knowledge Base / RAG ----
KB_DIR=./knowledge_base
CHROMA_DIR=./knowledge_base/chroma
KB_COLLECTION=saudi_regulations
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RETRIEVAL_TOP_K=8
RESPECT_ROBOTS=true
# Managed vector store (Chroma Cloud) — when CHROMA_API_KEY is set the app uses
# hosted Chroma instead of the local CHROMA_DIR. tenant + database come from the
# Chroma Cloud console. Leave empty to keep the local on-disk store.
# CHROMA_API_KEY=ck-xxxxxxxx
# CHROMA_TENANT=00000000-0000-0000-0000-000000000000
# CHROMA_DATABASE=waaem
# Auto-build the KB from official sources on first startup when empty:
KB_AUTO_BUILD=true
# Periodic re-check of official sources (hours); 0 disables. e.g. 168 = weekly:
KB_UPDATE_INTERVAL_HOURS=0
# Add extra authorities/docs without code by pointing to a JSON list:
# KB_SOURCES_FILE=./knowledge_base/extra_sources.json

# ---- AI (Meta Llama via Ollama) ----
OLLAMA_HOST=http://localhost:11434
LLAMA_MODEL=llama3.1
LLAMA_TIMEOUT=120
LLAMA_MAX_RETRIES=2
# When the model is unreachable/invalid, serve the curated analysis so the
# product stays functional. Set to false to require a live model.
AI_ALLOW_FALLBACK=true
# Optional llama.cpp OpenAI-compatible endpoint fallback:
# LLAMACPP_URL=http://localhost:8080
LLAMACPP_URL=
